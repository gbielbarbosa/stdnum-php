{
    "name": "gbielbarboza/stdnum-php",
    "description": "Library to parse, validate and format standard numbers and identifiers.",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Gabriel da Silva Barbosa",
            "email": "gabrielbarbosak1@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "illuminate/validation": "^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "StdNum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StdNum\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit"
    }
}